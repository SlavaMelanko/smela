{
  "name": "smela",
  "private": true,
  "workspaces": [
    "apps/web",
    "apps/api",
    "packages/e2e",
    "packages/i18n",
    "packages/eslint",
    "packages/ui"
  ],
  "engines": {
    "bun": ">=1"
  },
  "devDependencies": {
    "husky": "^9.1.7",
    "prettier": "^3.8.1"
  },
  "scripts": {
    "clean": "bun run --filter @smela/api clean & bun run --filter @smela/web clean & bun run --filter @smela/ui clean & bun run --filter @smela/i18n clean & bun run --filter @smela/e2e clean & rm -rf node_modules & wait",
    "reinstall": "bun run clean && bun install",
    "prepare": "husky",
    "postinstall": "bun run --filter @smela/i18n sync",
    "dev:web": "bash scripts/dev.sh",
    "dev:web:kill": "bash scripts/dev.sh --kill",
    "check:web": "bun run --filter @smela/web check",
    "check:ui": "bun run --filter @smela/ui check",
    "check:api": "bun run --filter @smela/api check",
    "check:i18n": "bun run --filter @smela/i18n check",
    "check:e2e": "bun run --filter @smela/e2e check",
    "check": "bun run check:e2e & bun run check:i18n & bun run check:ui & bun run check:web & bun run check:api & wait",
    "e2e:web": "bash scripts/e2e.sh",
    "e2e:web:ui": "bash scripts/e2e.sh --ui",
    "e2e:web:kill": "bash scripts/e2e.sh --kill"
  }
}
