{
  "name": "smela",
  "private": true,
  "version": "2026.03.20",
  "engines": {
    "node": ">=22",
    "pnpm": ">=10"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "scripts": {
    "prepare": "husky",
    "install:all": "pnpm install && cd apps/api && bun install",
    "dev:web": "pnpm --filter @smela/web dev",
    "dev:api": "bun --cwd apps/api run dev",
    "build:web": "pnpm --filter @smela/web build",
    "build:api": "bun --cwd apps/api run build",
    "lint:web": "pnpm --filter @smela/web lint",
    "lint:api": "bun --cwd apps/api run lint",
    "test:web": "pnpm --filter @smela/web test",
    "test:api": "bun run --cwd apps/api test",
    "test": "pnpm run test:api && pnpm run test:web",
    "db:dev:up": "docker compose -f docker-compose-dev.yml --env-file apps/api/.env.development up -d --wait",
    "db:dev:down": "docker compose -f docker-compose-dev.yml --env-file apps/api/.env.development down -v",
    "db:dev:reset": "pnpm run db:dev:down && pnpm run db:dev:up && bun --cwd apps/api run db:init"
  }
}
