{
  "name": "smela",
  "private": true,
  "workspaces": [
    "apps/*",
    "packages/*"
  ],
  "engines": {
    "bun": ">=1.3.11"
  },
  "devDependencies": {
    "@playwright/test": "^1.59.1",
    "eslint": "^10.3.0",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.2",
    "prettier": "^3.8.3",
    "typescript": "^6.0.3"
  },
  "scripts": {
    "clean": "bun run --parallel --filter '*' clean & rm -rf node_modules & wait",
    "reinstall": "bun pm cache rm && bun run clean && bun install",
    "prepare": "husky",
    "postinstall": "bun run --filter @smela/i18n sync",
    "dev:web": "bash scripts/dev.sh",
    "format:web": "bun run --parallel --filter '@smela/i18n' --filter '@smela/ui' --filter '@smela/web' format",
    "lint:web": "bun run --parallel --filter '@smela/i18n' --filter '@smela/ui' --filter '@smela/web' lint",
    "coverage:web": "bun run --filter '@smela/ui' coverage",
    "check:admin": "bun run --filter @smela/admin check",
    "check:api": "bun run --filter @smela/api check",
    "check:e2e": "bun run --filter @smela/e2e check",
    "check:i18n": "bun run --filter @smela/i18n check",
    "check:ui": "bun run --filter @smela/ui check",
    "check:web": "bun run --filter @smela/web check",
    "check": "bun run --filter '*' check",
    "e2e:web": "bash scripts/e2e.sh --web",
    "e2e:web:ui": "bash scripts/e2e.sh --web --ui",
    "e2e:admin": "bash scripts/e2e.sh --admin",
    "e2e:admin:ui": "bash scripts/e2e.sh --admin --ui"
  }
}
