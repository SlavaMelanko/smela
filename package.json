{
  "name": "smela",
  "private": true,
  "version": "2026.03.20",
  "workspaces": ["apps/web", "apps/api"],
  "engines": {
    "bun": ">=1"
  },
  "devDependencies": {
    "husky": "^9.1.7"
  },
  "scripts": {
    "prepare": "husky",
    "dev:web": "bun run --filter @smela/web run dev",
    "dev:api": "bun run --filter @smela/api run dev",
    "dev": "bun run dev:api & bun run dev:web",
    "build:web": "bun run --filter @smela/web run build",
    "build:api": "bun run --filter @smela/api run build",
    "lint:web": "bun run --filter @smela/web run lint",
    "lint:api": "bun run --filter @smela/api run lint",
    "lint": "bun run lint:api && bun run lint:web",
    "test:web": "bun run --filter @smela/web run test",
    "test:api": "bun run --filter @smela/api run test",
    "test": "bun run test:api && bun run test:web",
    "db:dev:up": "bun run --filter @smela/api run db:dev:up",
    "db:dev:down": "bun run --filter @smela/api run db:dev:down",
    "db:dev:reset": "bun run --filter @smela/api run db:dev:reset"
  }
}
