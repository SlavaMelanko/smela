{
  "name": "@smela/web",
  "private": true,
  "version": "2026.03.26",
  "type": "module",
  "scripts": {
    "clean": "rm -rf node_modules",
    "reinstall": "bun run clean && bun install",
    "dev": "vite --mode development",
    "preview": "vite preview --mode production",
    "build": "vite build --mode production",
    "e2e": "NODE_ENV=test bunx playwright test -x",
    "e2e:ui": "NODE_ENV=test bunx playwright test --ui",
    "format": "prettier --check .",
    "format:fix": "prettier --write .",
    "lint": "eslint src e2e",
    "lint:fix": "eslint src e2e --fix",
    "lint:staged": "lint-staged",
    "check": "bun run format:fix && bun run lint:fix",
    "bundle:analyze": "ANALYZE_BUNDLE=true bun run build"
  },
  "lint-staged": {
    "*.{js,jsx}": [
      "eslint --max-warnings=0 --fix",
      "prettier --ignore-unknown --write"
    ]
  },
  "dependencies": {
    "@smela/ui": "workspace:*",
    "@smela/i18n": "workspace:*",
    "@sentry/react": "^10.39.0",
    "i18next": "^25.8.11",
    "i18next-http-backend": "^3.0.2",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "react-i18next": "^16.5.3",
    "react-router-dom": "^7.12.0"
  },
  "devDependencies": {
    "@smela/eslint": "workspace:*",
    "@smela/e2e": "workspace:*",
    "@playwright/test": "^1.58.2",
    "@sentry/vite-plugin": "^4.9.1",
    "@tailwindcss/vite": "^4.2.0",
    "tailwindcss": "^4.2.0",
    "@types/node": "^25.2.3",
    "@vitejs/plugin-react": "^5.1.4",
    "babel-plugin-react-compiler": "^1.0.0",
    "eslint": "^9.39.2",
    "globals": "^17.0.0",
    "rollup-plugin-visualizer": "^6.0.5",
    "rollup-plugin-webpack-stats": "^2.1.11",
    "vite": "^7.3.1"
  }
}
