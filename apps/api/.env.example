# Core
NODE_ENV=development
LOG_LEVEL=info

# Database
POSTGRES_DEBUG=false # enable SQL query logging
POSTGRES_USER=admin
POSTGRES_PASSWORD=password
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=smela_back
POSTGRES_MAX_CONNECTIONS=4

SEED_USER_PASSWORD=your-seed-password # default password for seeded users
SEED_USER_PASSWORD_HASH=your-bcrypt-hash # pre-computed bcrypt hash for fake user seeding

# Network
JWT_SECRET=your-secret-key-min-10-chars
# JWT_SECRET_PREVIOUS=your-previous-secret-key # optional, for secret rotation
JWT_EXPIRATION=900 # 15 minutes
COOKIE_REFRESH_TOKEN_NAME=refresh-token
COOKIE_REFRESH_TOKEN_EXPIRATION=86400 # 24 hours
COOKIE_REFRESH_TOKEN_DOMAIN=localhost # required for staging/production
ALLOWED_ORIGINS=http://localhost:5173 # required for staging/production
BE_BASE_URL=http://localhost:3000
FE_USER_URL=http://localhost:5173
FE_ADMIN_URL=http://localhost:5175

# Email
# Resend has highest priority - if API key is provided, it will be used
EMAIL_RESEND_API_KEY=your-resend-api-key
# Ethereal is used as fallback if Resend API key is not provided
EMAIL_ETHEREAL_HOST=smtp.ethereal.email
EMAIL_ETHEREAL_PORT=587
EMAIL_ETHEREAL_USERNAME=username@ethereal.email
EMAIL_ETHEREAL_PASSWORD=password

EMAIL_SENDER_PROFILES={ "system": { "email": "noreply@smela.me", "name": "SMELA" } }

# Company
COMPANY_NAME=SMELA
COMPANY_SOCIAL_LINKS={ "twitter": "https://twitter.com/example" }

# Services
CAPTCHA_SECRET_KEY=your-recaptcha-secret-key
SENTRY_DSN=https://your-sentry-dsn

# =============================================================================
# CI/CD secrets only (not needed for local development)
# =============================================================================

# Codecov token for code coverage reports
# Get from: https://app.codecov.io/gh/<github-profile>/<repository>/config/general
# CODECOV_TOKEN=

# AI-assistant to review pull requests and suggest improvements
# Can be generated via `claude setup-token` (requires Pro subscription or above)
# CLAUDE_CODE_OAUTH_TOKEN=
