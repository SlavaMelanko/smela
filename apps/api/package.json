{
  "name": "@smela/api",
  "version": "2026.03.20",
  "scripts": {
    "prepare": "husky",
    "clean": "bun pm cache rm && rm -rf node_modules bun.lock",
    "reinstall": "bun clean && bun install",
    "dev": "bun --watch src/app.ts",
    "build": "NODE_ENV=production bun build src/app.ts --outdir dist --target bun --minify",
    "build:staging": "NODE_ENV=staging bun build src/app.ts --outdir dist --target bun --sourcemap=external",
    "db:generate": "drizzle-kit generate",
    "db:migrate": "drizzle-kit migrate",
    "db:migrate:custom": "bun src/data/migrations/custom/run.ts",
    "db:seed": "bun src/data/scripts/seed.ts",
    "db:init": "bun run db:generate && bun run db:migrate && bun run db:migrate:custom && bun run db:seed",
    "db:dev:up": "docker compose -f docker-compose-dev.yml --env-file .env.development up -d --wait",
    "db:dev:down": "docker compose -f docker-compose-dev.yml --env-file .env.development down -v",
    "db:dev:reset": "bun run db:dev:down && bun run db:dev:up && NODE_ENV=development bun run db:init",
    "db:ui": "drizzle-kit studio",
    "test": "NODE_ENV=test bun test src",
    "coverage": "NODE_ENV=test bun test src --coverage",
    "lint": "bunx eslint --cache src",
    "lint:fix": "bunx eslint --cache --fix src",
    "tsc": "bunx tsc --noEmit",
    "check": "bun run lint:fix && bun run tsc && bun run test",
    "emails": "email dev --dir src/emails --port 3001",
    "docker:build": "docker build -t smela-back --target production .",
    "docker:build:staging": "docker build -t smela-back-staging --target staging .",
    "docker:test": "docker build -t smela-back-test --target test . && docker run --rm smela-back-test"
  },
  "dependencies": {
    "@hono/zod-validator": "^0.7.6",
    "@react-email/components": "^1.0.8",
    "@sentry/bun": "^10.30.0",
    "bcrypt": "^6.0.0",
    "dotenv": "^17.2.3",
    "drizzle-orm": "^0.45.1",
    "hono": "^4.10.7",
    "hono-pino": "^0.10.3",
    "hono-rate-limiter": "^0.5.3",
    "http-status-codes": "^2.3.0",
    "pg": "^8.16.3",
    "pino": "^10.1.0",
    "react": "^19.2.0",
    "react-dom": "^19.2.0",
    "resend": "^6.5.2"
  },
  "devDependencies": {
    "@antfu/eslint-config": "^7.4.3",
    "@faker-js/faker": "^10.1.0",
    "@react-email/preview-server": "^5.2.8",
    "@types/bcrypt": "^6.0.0",
    "@types/bun": "latest",
    "@types/nodemailer": "^7.0.10",
    "@types/pg": "^8.15.6",
    "@types/react": "^19.2.14",
    "@types/react-dom": "^19.2.3",
    "drizzle-kit": "^0.31.7",
    "eslint": "^10.0.0",
    "eslint-plugin-format": "^1.4.0",
    "husky": "^9.1.7",
    "nodemailer": "^8.0.1",
    "pino-pretty": "^13.1.2",
    "react-email": "^5.2.8"
  }
}
