# App name
VITE_APP_NAME=SMELA

# reCAPTCHA site key
# Development/Test: Use 6LeIxAcTAAAAAJcZVRqyHh71UMIEGNQ_MXjiZKhI (always passes)
# Production/Staging: Use your actual site key
VITE_CAPTCHA_SITE_KEY=

# Backend API URL
# Development/Test: http://localhost:3000
# Production/Staging: Your API URL (e.g., https://api.example.com)
VITE_BE_BASE_URL=

# Sentry DSN for error tracking
# Get from: https://sentry.io/settings/projects/<project>/keys/
VITE_SENTRY_DSN=

# =============================================================================
# E2E test user credentials
# =============================================================================

# Mailisk credentials (for email testing)
# Get test credentials from https://mailisk.com
VITE_MAILISK_API_KEY=
VITE_MAILISK_NAMESPACE=

# Predefined user credentials
VITE_E2E_OWNER_EMAIL=owner@smela.me
VITE_E2E_OWNER_PASSWORD=
VITE_E2E_ADMIN_EMAIL=admin@smela.me
VITE_E2E_ADMIN_PASSWORD=
VITE_E2E_SUPPORT_EMAIL=support@smela.me
VITE_E2E_SUPPORT_PASSWORD=
VITE_E2E_STRONG_PASSWORD=

# =============================================================================
# CI/CD secrets only (not needed for local development)
# =============================================================================

# RelativeCI API key for bundle analysis
# Get from: https://app.relative-ci.com/projects/zeITj9gEk1AMeNTP87R8/settings/keys
# RELATIVE_CI_KEY=

# Codecov token for code coverage reports
# Get from: https://app.codecov.io/gh/<github-profile>/<repository>/config/general
# CODECOV_TOKEN=

# Sentry authentication token for uploading source maps and creating releases
# Get from: https://sentry.io/settings/account/api/auth-tokens/
# SENTRY_AUTH_TOKEN=

# AI-assistant to review pull requests and suggest improvements
# Can be generated via `claude setup-token` (requires Pro subscription or above)
# CLAUDE_CODE_OAUTH_TOKEN=
