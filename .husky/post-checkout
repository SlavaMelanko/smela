#!/bin/sh
set -e

PREV_HEAD=$1
NEW_HEAD=$2
BRANCH_CHECKOUT=$3

[ "$PREV_HEAD" = "0000000000000000000000000000000000000000" ] && exit 0
[ "$BRANCH_CHECKOUT" != "1" ] && exit 0

if git diff --name-only "$PREV_HEAD" "$NEW_HEAD" | grep -qE "^apps/api/(package\.json|bun\.lock)$"; then
  bun install --cwd apps/api || echo "Warning: bun install failed, run manually"
fi

if git diff --name-only "$PREV_HEAD" "$NEW_HEAD" | grep -q "^pnpm-lock\.yaml$"; then
  pnpm install || echo "Warning: pnpm install failed, run manually"
fi
