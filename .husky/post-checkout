#!/bin/sh
set -e

# Auto-runs install after branch switch if the lockfile changed between branches,
# so node_modules stays in sync without manual intervention.

PREV_HEAD=$1
NEW_HEAD=$2
BRANCH_CHECKOUT=$3

[ "$PREV_HEAD" = "0000000000000000000000000000000000000000" ] && exit 0
[ "$BRANCH_CHECKOUT" != "1" ] && exit 0

if git diff --name-only "$PREV_HEAD" "$NEW_HEAD" | grep -qE "^(bun\.lock|apps/(web|api)/package\.json)$"; then
  bun install || echo "Warning: bun install failed, run manually"
fi
